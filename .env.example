# Copy this file to .env. The launcher creates local secrets when possible.
# Never share .env, data/, backups/ or n8n-data/.

# --- Optional AI ---
GEMINI_API_KEY=
WHISPER_MODEL=tiny
WHISPER_PYTHON=python3

# --- Local security ---
N8N_ENCRYPTION_KEY=

# --- HTTP server (to connect it to ChatGPT via a tunnel) ---
MCP_HTTP_PORT=3333
# Protects the /mcp endpoint with a token: generate one with `openssl rand -hex 16`.
# Without this, anyone with the tunnel URL can use your server.
MCP_AUTH_TOKEN=

# --- YouTube Data API v3 (free, recommended) ---
# Without this: list_videos still works via yt-dlp (views are fine, no exact likes/tags, sometimes null).
# With this: exact likes/tags + enables get_trending_videos.
# Generate one for free at: https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3").
YOUTUBE_API_KEY=

# --- Storage ---
DATABASE_PATH=/app/data/creator-research.db

# --- yt-dlp: extra args for special cases ---
# Example, rate-limited Instagram: --cookies-from-browser chrome
YTDLP_EXTRA_ARGS=
