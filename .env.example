# Copiá este archivo a .env y completá tus credenciales — .env nunca se sube al repo (gitignored).
# Todo es opcional: el server funciona sin nada de esto (client-reasoning, 100% gratis, sin IA propia).

# --- Servidor HTTP (para conectarlo a ChatGPT vía túnel) ---
MCP_HTTP_PORT=3333
# Protege el endpoint /mcp con un token: generalo con `openssl rand -hex 16`.
# Sin esto, cualquiera con la URL del túnel puede usar tu servidor.
MCP_AUTH_TOKEN=

# --- YouTube Data API v3 (gratis, recomendado) ---
# Sin esto: list_videos funciona igual vía yt-dlp (vistas ok, sin likes/tags exactos, a veces null).
# Con esto: likes/tags exactos + habilita get_trending_videos.
# Generarla gratis en: https://console.cloud.google.com/apis/credentials (habilitar "YouTube Data API v3").
YOUTUBE_API_KEY=

# --- Almacenamiento ---
DATABASE_PATH=./data/creator-research.db

# --- yt-dlp: args extra para casos especiales ---
# Ejemplo Instagram con rate-limit: --cookies-from-browser chrome
YTDLP_EXTRA_ARGS=
