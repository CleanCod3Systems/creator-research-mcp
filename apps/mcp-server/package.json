{
  "name": "creator-research-mcp",
  "version": "0.5.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx watch src/index.ts",
    "start:stdio": "tsx src/index.ts",
    "start:http": "tsx src/http.ts"
  },
  "dependencies": {
    "@cleancod3/core": "workspace:*",
    "@cleancod3/db": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1",
    "@cleancod3/providers": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "description": "MCP server that turns videos, channels, articles, and PDFs into structured knowledge",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "youtube",
    "transcript",
    "knowledge",
    "claude",
    "chatgpt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CleanCod3Systems/creator-research-mcp",
    "directory": "apps/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "creator-research-mcp": "./dist/bin.js"
  },
  "files": [
    "dist"
  ]
}
